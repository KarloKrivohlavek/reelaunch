---
/**
 * Contact page
 * URL: /contact
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import { Hero } from '@/components/hero';
import ContactForm from '@/components/patterns/ContactForm.astro';
import siteConfig from '@/config/site.config';
import { resolveSocialLinks } from '@/lib/utils';

const socialLinks = resolveSocialLinks(siteConfig.socialLinks);

const channels = [
  {
    icon: 'mail',
    label: 'Email',
    value: siteConfig.email,
    note: 'Drop us a line',
    href: `mailto:${siteConfig.email}`,
    external: false,
  },
  ...socialLinks.map((link) => ({
    icon: link.icon,
    label: link.label,
    value: link.href.replace(/^https?:\/\/(www\.)?/, ''),
    note: 'Follow along',
    href: link.href,
    external: true,
  })),
];
---

<PageLayout title="Contact — Reelaunch" description="Get in touch" eagerReveal>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="mail" size="sm" />
      Get in touch
    </Badge>

    <h1 slot="title">
      Send us a <span class="text-brand-500">message.</span>
    </h1>

    <p slot="description">
      Use the form below or reach out on any of these channels. We'll get back to you within 1
      business day.
    </p>
  </Hero>

  <!-- Contact Section -->
  <section class="bg-background-secondary border-border border-t py-[var(--space-section-md)]">
    <div class="mx-auto max-w-5xl px-6">
      <div class="grid grid-cols-1 items-stretch gap-10 lg:grid-cols-5 lg:gap-16">
        <!-- Left column: contact form -->
        <div class="h-full lg:col-span-3" data-reveal>
          <Card padding="lg" class="flex h-full flex-col justify-center">
            <h2 class="font-display text-foreground mb-6 text-xl font-bold">Send a message</h2>
            <ContactForm />
          </Card>
        </div>

        <!-- Right column: contact channels -->
        <div class="space-y-4 lg:col-span-2" data-reveal data-reveal-delay="1">
          <div>
            <h2 class="font-display text-foreground mb-1 text-lg font-bold">Other channels</h2>
            <p class="text-foreground-muted text-sm">
              Prefer a direct channel? Pick whichever works best.
            </p>
          </div>

          <!-- Channel list -->
          <div class="space-y-2">
            {
              channels.map((ch) => (
                <a
                  href={ch.href}
                  {...(ch.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  class="group block"
                >
                  <Card hover padding="sm" class="h-full">
                    <div class="flex items-center gap-3">
                      <div class="from-brand-500/20 to-brand-500/5 text-brand-500 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br">
                        <Icon name={ch.icon} size="sm" />
                      </div>
                      <div class="min-w-0 flex-1">
                        <p class="text-foreground text-sm font-semibold">{ch.label}</p>
                        <p class="text-foreground-muted truncate text-xs">{ch.value}</p>
                      </div>
                      <Icon
                        name="arrow-up-right"
                        size="sm"
                        class="text-foreground-muted group-hover:text-brand-500 shrink-0 transition-colors"
                      />
                    </div>
                  </Card>
                </a>
              ))
            }
          </div>

          <!-- Location card -->
          <Card hover padding="sm" class="bg-brand-500/5 border-brand-500/20">
            <div class="flex items-center gap-3">
              <div
                class="from-brand-500/20 to-brand-500/5 text-brand-500 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br"
              >
                <Icon name="map-pin" size="sm" />
              </div>
              <div>
                <p class="text-foreground text-sm font-semibold">
                  {siteConfig.address?.city ?? 'Your City'}
                </p>
                <p class="text-foreground-muted mt-0.5 text-xs">
                  Based in {siteConfig.address?.country ?? 'Your Country'}
                </p>
              </div>
            </div>
          </Card>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
